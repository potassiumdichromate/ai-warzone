# ─── Server ────────────────────────────────────────────────
PORT=3001

# ─── MongoDB ────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/warzone_ai
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/warzone_ai
MONGODB_URI=mongodb://localhost:27017/warzone_ai

# ─── 0G Network (MAINNET) ───────────────────────────────────
# Chain ID: 16661
# Explorer: https://chainscan.0g.ai

# Storage Indexer — used for file upload/download
ZERO_G_INDEXER_RPC=https://indexer-storage-turbo.0g.ai

# EVM RPC — used for on-chain transactions (paying for storage)
ZERO_G_EVM_RPC=https://evmrpc.0g.ai

# Flow contract on mainnet
ZERO_G_FLOW_ADDRESS=0x62D4144dB0F0a6fBBaeb6296c785C71B3D57C526

# Private key of the BACKEND WALLET that pays for 0G Storage uploads
# NEVER commit this value. Keep it only in this .env file.
ZERO_G_PRIVATE_KEY=your_private_key_here

# ─── Training ────────────────────────────────────────────────
# How many samples a wallet must accumulate before training starts
MIN_SAMPLES_FOR_TRAINING=500
